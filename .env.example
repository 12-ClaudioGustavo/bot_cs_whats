# =============================================
# BOT WHATSAPP - CONFIGURAÇÕES DE AMBIENTE
# =============================================
# Copie este ficheiro para .env e preencha os valores

# --- SUPABASE ---
SUPABASE_URL=https://SEU_PROJETO.supabase.co
SUPABASE_ANON_KEY=sua_chave_anon_aqui
SUPABASE_SERVICE_KEY=sua_chave_service_aqui

# --- EMPRESA ---
COMPANY_NAME=TechSoft Solutions
COMPANY_PHONE=+244 XXX XXX XXX
COMPANY_EMAIL=contato@techsoft.co.ao
COMPANY_WEBSITE=https://www.techsoft.co.ao
COMPANY_ADDRESS=Luanda, Angola

# --- HORÁRIO DE FUNCIONAMENTO ---
# Dias: 0=Domingo, 1=Segunda, ..., 5=Sexta, 6=Sábado
BUSINESS_DAYS_START=1
BUSINESS_DAYS_END=5
BUSINESS_HOUR_START=8
BUSINESS_HOUR_END=18
BUSINESS_TIMEZONE=Africa/Luanda

# --- ATENDIMENTO HUMANO ---
# Número do atendente para encaminhamento (com código do país, sem espaços)
HUMAN_ATTENDANT_PHONE=244900000000
HUMAN_ATTENDANT_NAME=Equipa de Suporte

# --- BOT ---
# Tempo de inatividade antes de resetar o fluxo (em minutos)
INACTIVITY_TIMEOUT_MINUTES=30

# --- LOGS ---
LOG_LEVEL=info
